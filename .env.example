
PORT=3000

NODE_ENV=development

# Secret key required in the X-API-Key header for sending messages.
# Generate a strong random value: any String or numbers
API_KEY=your_strong_api_key_here
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

# Sliding-window duration in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests allowed within the window per IP
RATE_LIMIT_MAX=100

# Unique identifier for this WhatsApp client / session.
WHATSAPP_CLIENT_ID=whatsapp-client

# Number of messages the BullMQ worker processes concurrently
MESSAGE_QUEUE_CONCURRENCY=5